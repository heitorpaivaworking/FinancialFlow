# ─── BANCO DE DADOS ───────────────────────────────────────
POSTGRES_DB=financeflow
POSTGRES_USER=financeflow
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── BACKEND ──────────────────────────────────────────────
DATABASE_URL=postgresql://financeflow:CHANGE_ME_IN_PRODUCTION@postgres:5432/financeflow
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
DEBUG=false
LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ─── FRONTEND ─────────────────────────────────────────────
VITE_API_URL=/api
VITE_APP_NAME=FinanceFlow
VITE_APP_VERSION=1.0.0
